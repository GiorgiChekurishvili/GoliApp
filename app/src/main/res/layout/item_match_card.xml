<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_match"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_scoreboard_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="16dp">


    <TextView
        android:id="@+id/tv_league_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="Premier League"
        android:textColor="#B8D4C8"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/badge_live"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:id="@+id/badge_live"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_live_badge"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_live_dot" />

        <TextView
            android:id="@+id/tv_live_minute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:text="67'"
            android:textColor="@color/off_white"
            android:textSize="11sp" />
    </LinearLayout>


    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="FT"
        android:textColor="@color/gold"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ImageView
        android:id="@+id/iv_home_logo"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_league_name"
        />

    <TextView
        android:id="@+id/tv_home_name"
        style="@style/Text.ScoreboardNumber"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Manchester United"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_home_logo"
        app:layout_constraintEnd_toStartOf="@id/tv_home_score"
        app:layout_constraintStart_toEndOf="@id/iv_home_logo"
        app:layout_constraintTop_toTopOf="@id/iv_home_logo" />

    <TextView
        android:id="@+id/tv_home_score"
        style="@style/Text.ScoreboardNumber"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="2"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_home_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_home_logo" />


    <View
        android:id="@+id/divider_gold"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="#33D4A537"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_home_logo" />


    <ImageView
        android:id="@+id/iv_away_logo"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="10dp"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider_gold" />

    <TextView
        android:id="@+id/tv_away_name"
        style="@style/Text.ScoreboardNumber"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Liverpool"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_away_logo"
        app:layout_constraintEnd_toStartOf="@id/tv_away_score"
        app:layout_constraintStart_toEndOf="@id/iv_away_logo"
        app:layout_constraintTop_toTopOf="@id/iv_away_logo" />

    <TextView
        android:id="@+id/tv_away_score"
        style="@style/Text.ScoreboardNumber"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="1"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_away_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_away_logo" />


    <ImageButton
        android:id="@+id/btn_favourite"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/add_to_favourites"
        android:padding="4dp"
        android:src="@drawable/ic_star_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_away_logo" />

</androidx.constraintlayout.widget.ConstraintLayout>